# ============================================================
# SideQuest.me — Root .gitignore
# Covers: Next.js (web/), Android/Kotlin (app/), shared/, docs/
# and Claude agent artefacts
# ============================================================

# ---- Next.js / Node (web/) --------------------------------
web/node_modules/
web/.next/
web/out/
web/.env
web/.env.local
web/.env.*.local
web/.vercel/
web/build/
web/dist/

# ---- Android / Kotlin (app/) ------------------------------
app/.gradle/
app/build/
app/local.properties
app/*.iml
app/.idea/
app/.idea/**
app/captures/
app/.externalNativeBuild/
app/.cxx/
app/google-services.json
app/keystore/
*.keystore
*.jks

# ---- Shared / Docs ----------------------------------------
shared/node_modules/
shared/dist/
shared/build/

# ---- Claude agent artefacts -------------------------------
.claude/
**/.claude/
*.claude_session
agent_memory.json
agent_scratch/

# ---- OS / Editor ------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
.idea/
*.swp
*.swo
.vscode/

# ---- Secrets (belt + braces) ------------------------------
.env
.env.*
!.env.example
*.pem
*.p12
service-account*.json
